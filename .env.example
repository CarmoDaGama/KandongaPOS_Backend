# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kandongapos

# JWT
JWT_SECRET=your-secret-key
JWT_EXPIRATION=3600
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRATION=604800

# App
NODE_ENV=development
PORT=3000

# OTP/SMS (Twilio or similar)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# IA
OPENAI_API_KEY=
GROK_API_KEY=

# Storage
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AGT Export
AGT_API_KEY=
AGT_ENDPOINT=
